---
import "../styles/global.css";
import { Content as Letter } from "../content/index.md";

const year = new Date().getFullYear();
const description =
    "We're looking for a small group of design partners to shape ooda before launch.";

// Absolute URLs for social cards (scrapers require absolute, not relative).
const ogImage = new URL("/og-image.png", Astro.site).href;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>ooda — Design partners</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={canonical} />
        <meta property="og:title" content="ooda — Design partners" />
        <meta property="og:description" content={description} />
        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonical} />
        <meta property="og:image" content={ogImage} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:image:alt" content="ooda — Design partners" />
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content="ooda — Design partners" />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={ogImage} />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
        <link
            href="https://cdn.jsdelivr.net/npm/geist@1/dist/fonts/geist-sans/style.css"
            rel="stylesheet"
        />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Caveat:wght@500;600&display=swap"
            rel="stylesheet"
        />
    </head>
    <body
        class="min-h-screen bg-white font-sans text-ink leading-[1.6] antialiased [text-rendering:optimizeLegibility]"
    >
        {/* Hand-drawn note pointing up at the browser's top edge. */}
        <div
            class="pointer-events-none fixed top-1 left-[120px] z-20 hidden flex-col items-center gap-0.5 text-ink-faint sm:flex"
            aria-hidden="true"
        >
            <svg width="18" height="22" viewBox="0 0 24 30" fill="none">
                <path
                    d="M12 28 C 8 20, 16 13, 12 4"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"></path>
                <path
                    d="M5 10 L 12 3 L 19 10"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
            </svg>
            <span
                class="font-display text-lg text-center leading-none whitespace-nowrap"
            >
                I'm hosted <br />on ooda
            </span>
        </div>

        <main
            class="mx-auto flex w-full max-w-[38rem] flex-col px-6 pt-16 pb-12"
        >
            <a
                href="https://ooda.run"
                class="mb-12 inline-block"
                aria-label="ooda"
            >
                <img src="/logo.svg" alt="ooda" class="h-auto w-20 md:w-24" />
            </a>

            {
                /* Body copy + signup form live in src/content/index.md — edit there. */
            }
            <div class="letter">
                <Letter />
            </div>

            <footer
                class="mt-16 flex flex-wrap justify-between gap-4 pt-8 text-sm opacity-50"
            >
                <span>&copy; {year} toy.studio</span>
                <a
                    href="https://ooda.run"
                    class="transition-colors hover-underline">ooda.run</a
                >
            </footer>
        </main>

        <script>
            // Publishable Plunk key (pk_*, safe client-side). Injected by ooda
            // as window.__OODA_ENV__.PLUNK_PUBLIC_KEY — set via:
            //   ooda secrets set PLUNK_PUBLIC_KEY=pk_... --env --site design-partners
            const PLUNK_PUBLIC_KEY = (window as any).__OODA_ENV__
                ?.PLUNK_PUBLIC_KEY as string | undefined;

            document.querySelectorAll("[data-signup-form]").forEach((form) => {
                form.addEventListener("submit", async (e) => {
                    e.preventDefault();
                    const formEl = e.target as HTMLFormElement;
                    const email = new FormData(formEl).get("email") as string;
                    if (!email) return;

                    const btn = formEl.querySelector("button")!;
                    const placement =
                        formEl.dataset.placement ?? "design-partners";

                    if (!PLUNK_PUBLIC_KEY) {
                        console.warn(
                            "PLUNK_PUBLIC_KEY missing — set it as an ooda env var (only available on the published site, not local dev).",
                        );
                        return;
                    }

                    btn.setAttribute("disabled", "");

                    try {
                        const res = await fetch(
                            "https://next-api.useplunk.com/v1/track",
                            {
                                method: "POST",
                                headers: {
                                    "Content-Type": "application/json",
                                    Authorization: `Bearer ${PLUNK_PUBLIC_KEY}`,
                                },
                                body: JSON.stringify({
                                    event: "waitlist-signup",
                                    email,
                                    // Same list as ooda.run, flagged so design partners can be segmented.
                                    data: {
                                        source: "design-partners.ooda.run",
                                        placement,
                                        designPartner: true,
                                    },
                                }),
                            },
                        );
                        if (!res.ok)
                            throw new Error(`Plunk responded ${res.status}`);

                        btn.querySelector(".btn-label")?.classList.add(
                            "hidden",
                        );
                        btn.querySelector(".btn-sent")?.classList.remove(
                            "hidden",
                        );
                        (
                            formEl.querySelector(
                                'input[type="email"]',
                            ) as HTMLInputElement
                        ).value = "";

                        setTimeout(() => {
                            btn.querySelector(".btn-label")?.classList.remove(
                                "hidden",
                            );
                            btn.querySelector(".btn-sent")?.classList.add(
                                "hidden",
                            );
                            btn.removeAttribute("disabled");
                        }, 3000);
                    } catch {
                        btn.removeAttribute("disabled");
                    }
                });
            });
        </script>
    </body>
</html>
